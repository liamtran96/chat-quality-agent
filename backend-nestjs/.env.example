# Server
SERVER_PORT=8080
APP_ENV=development

# Database (PostgreSQL) — use DATABASE_URL or individual vars
# DATABASE_URL=postgresql://cqa:secret@localhost:5432/cqa
DB_HOST=localhost
DB_PORT=5432
DB_USER=cqa
DB_PASSWORD=secret
DB_NAME=cqa

# Security
JWT_SECRET=change-me-to-at-least-32-characters-long
ENCRYPTION_KEY=change-me-exactly-32-bytes-long!

# Rate limiting (requests per minute)
RATE_LIMIT_PER_IP=500
RATE_LIMIT_PER_USER=1000
